{
  "manifest_version": 3,
  "name": "JUST TNP Scraper",
  "version": "2.6.5",
  "description": "JUST TNP Scraper — scrape BIT Mesra TNP, filter by branch + CTC range, sort by compensation, view in an interactive viewer with AI-powered insights.",
  "permissions": ["activeTab", "scripting", "downloads", "storage"],
  "host_permissions": [
    "https://tp.bitmesra.co.in/*",
    "http://tp.bitmesra.co.in/*",
    "https://*.bitmesra.co.in/*",
    "https://*.bitmesra.ac.in/*",
    "https://api.groq.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BIT TNP Scraper"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
